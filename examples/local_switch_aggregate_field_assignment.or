package examples.aggregates

record Entry
    status: UInt32
    code: UInt32

record Page
    entries: Array<Entry, 2>
    count: UInt32

unsafe function selected_status(flag: Bool) -> UInt32
    var page = Page([Entry(1 as UInt32, 10 as UInt32), Entry(2 as UInt32, 20 as UInt32)], 2 as UInt32)
    switch flag
        true =>
            page.entries[1 as UInt64].status = 19 as UInt32
        false =>
            page.entries[1 as UInt64].status = 23 as UInt32
    page.entries[1 as UInt64].status

unsafe function main() -> UInt32
    let value = selected_status(true)
    0 as UInt32
