package examples.viewdescriptor

function count(values: shared.View<UInt32>) -> IntSize
    values.length()

function first(values: exclusive.View<UInt32>) -> UInt32
    values[0]

function sum(values: shared.View<UInt32>) -> UInt32
    var total = 0 as UInt32
    for item in values
        total = total + item
    total
