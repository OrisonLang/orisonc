package examples.aggregates

record Entry
    status: UInt32
    code: UInt32

function selected_status() -> UInt32
    let entries = [Entry(3 as UInt32, 10 as UInt32), Entry(7 as UInt32, 20 as UInt32)]
    entries[1 as UInt64].status

function main() -> UInt32
    let value = selected_status()
    0 as UInt32
